# TON Smart Contract
CONTRACT_ADDRESS=EQA...your_testnet_contract_address

# Operator wallet (24-word mnemonic — KEEP SECRET)
OPERATOR_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# TonCenter API key (get at https://toncenter.com)
TONCENTER_API_KEY=your_api_key_here
TONCENTER_BASE_URL=https://testnet.toncenter.com/api/v2

# Database
DATABASE_URL=sqlite+aiosqlite:///./mini_rollup.db

# Auto-settle: settle batch every N pending transactions (0 = manual only)
AUTO_SETTLE_TX_COUNT=10

# Dispute window in seconds (matches contract)
DISPUTE_WINDOW_SECONDS=3600

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
